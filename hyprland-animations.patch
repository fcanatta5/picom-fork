+# ----------------------------------------------------------------------------
+# 11. Regras antigas suportadas, mas substituídas por `rules`
+# ----------------------------------------------------------------------------
+# Formato geral: lista de condições C2. Deixe comentadas se `rules` estiver ativo.
+# transparent-clipping-exclude = [];
+# shadow-exclude = [];
+# clip-shadow-above = [];
+# fade-exclude = [];
+# focus-exclude = [];
+# invert-color-include = [];
+# blur-background-exclude = [];
+# unredir-if-possible-exclude = [];
+# rounded-corners-exclude = [];
+#
+# corner-radius-rules: cada string usa prefixo numérico, ex. "12:class_g = 'Alacritty'".
+# corner-radius-rules = [];
+#
+# opacity-rule: prefixo 0-100, ex. "90:class_g = 'kitty'".
+# opacity-rule = [];
+#
+# window-shader-fg-rule: prefixo shader, ex. "shader.frag:class_g = 'mpv'".
+# window-shader-fg-rule = [];
+
+# ----------------------------------------------------------------------------
+# 12. wintypes antigo suportado, mas comentado porque `rules` está ativo
+# ----------------------------------------------------------------------------
+# Cada tipo aceita: shadow, fade, focus, opacity, blur-background, full-shadow,
