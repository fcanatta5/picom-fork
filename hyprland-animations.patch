+#   tooltip = { shadow = true; fade = true; focus = true; opacity = 0.92; blur-background = true; full-shadow = false; redir-ignore = false; clip-shadow-above = false; };
+#   dock = { shadow = false; fade = false; focus = true; opacity = 1.0; blur-background = false; full-shadow = false; redir-ignore = false; clip-shadow-above = false; };
+#   desktop = { shadow = false; fade = false; focus = true; opacity = 1.0; blur-background = false; full-shadow = false; redir-ignore = false; clip-shadow-above = false; };
+# };
+
+# ----------------------------------------------------------------------------
+# 13. Opções aceitas mas depreciadas
+# ----------------------------------------------------------------------------
+# refresh-rate: depreciado; não use.
+# refresh-rate = 0;
+# resize-damage: depreciado; não use.
+# resize-damage = 0;
